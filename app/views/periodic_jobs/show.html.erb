<div class="contextual">
  <%= link_to sprite_icon('edit', l(:button_update)), { :controller => 'periodic_jobs', :action => 'edit', :id => @periodic_job } %>
  <%= link_to sprite_icon('del', l(:button_delete)), { :controller => 'periodic_jobs', :action => 'destroy', :id => @periodic_job },
              :confirm => l(:text_are_you_sure), :method => :delete %>
</div>

<h2><%= link_to l(:label_periodic_job_plural), periodic_jobs_path %> &#187; <%= h @periodic_job.title %></h2>

<h3><%= h @periodic_job.path %></h3>

<p><%= "#{t(:field_periodicity)} : #{@periodic_job.periodicity} (#{Cronex::ExpressionDescriptor.new(@periodic_job.periodicity).description})" if @periodic_job.periodicity.present? %></p>

<div class="box">
  <p><%= simple_format(h(@job_content)) %></p>
</div>

<% html_title(l(:label_periodic_job_plural)) -%>
